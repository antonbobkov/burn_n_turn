{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Wpedantic -Werror"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Clang Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-g"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Clang Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O3 -DNDEBUG",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "YES"
      }
    }
  ],
  "testPresets": [
    {
      "name": "unit",
      "configurePreset": "debug",
      "displayName": "Unit tests (no SDL, no simulation)",
      "filter": { "include": { "label": "unit" } }
    },
    {
      "name": "integration",
      "configurePreset": "debug",
      "displayName": "Integration tests (unit + simulation, no SDL)",
      "filter": { "include": { "label": "unit|simulation" } }
    },
    {
      "name": "sdl",
      "configurePreset": "debug",
      "displayName": "SDL tests",
      "filter": { "include": { "label": "sdl" } }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    }
  ]
}